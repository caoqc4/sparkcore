# =============================================================================
# SparkCore — Environment Variables
# =============================================================================
# Copy this file to .env.local (for local dev) or .env (for self-hosted).
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-side only.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase  (required)
# Create a project at https://supabase.com and get these from:
# Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# App URL  (required)
# Set to http://localhost:3000 for local dev, or your production domain.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# LLM — Text generation  (at least one required)
#
# Option A: Google AI Studio (recommended for quick start)
#   Get key at: https://aistudio.google.com/apikey
#   Also accepted as GEMINI_API_KEY
#
# Option B: LiteLLM proxy (recommended for production / multi-model routing)
#   Run the included proxy: scripts/start-litellm-proxy.sh
#   Or point to any OpenAI-compatible endpoint.
# -----------------------------------------------------------------------------
GOOGLE_AI_STUDIO_API_KEY=
# GEMINI_API_KEY=          # alias for GOOGLE_AI_STUDIO_API_KEY

# LiteLLM proxy (optional — used when routing through a local or hosted gateway)
# LITELLM_BASE_URL=http://localhost:4000
# LITELLM_API_KEY=sk-sparkcore-local-dev

# Replicate (optional — used by the included LiteLLM proxy config)
#   Get key at: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=
# REPLICATE_API_TOKEN=     # alias for REPLICATE_API_KEY


# -----------------------------------------------------------------------------
# Image generation  (optional — required for role portrait generation)
#   Get key at: https://fal.ai/dashboard/keys
#   Also accepted as FAL_API_KEY
# -----------------------------------------------------------------------------
FAL_KEY=


# -----------------------------------------------------------------------------
# Voice / Text-to-speech  (optional — enable the voice message feature)
#
# Option A: Azure Speech
#   https://portal.azure.com → Create Speech resource → Keys and Endpoint
#
# Option B: ElevenLabs
#   https://elevenlabs.io/app/settings/api-keys
# -----------------------------------------------------------------------------
# AZURE_SPEECH_API_KEY=
# AZURE_SPEECH_REGION=eastus

# ELEVENLABS_API_KEY=


# -----------------------------------------------------------------------------
# IM channels  (all optional — enable whichever channels you need)
# -----------------------------------------------------------------------------

# Telegram
#   1. Create a bot via @BotFather on Telegram
#   2. Run: pnpm tsx scripts/telegram-set-webhook.ts
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=    # any random string, used to verify webhook calls
# TELEGRAM_BOT_USERNAME=      # e.g. MyBotName (without @)

# Telegram — multi-bot per character channel (optional, overrides the above)
# TELEGRAM_BOT_TOKEN_CARIA=
# TELEGRAM_BOT_TOKEN_TEVEN=
# TELEGRAM_BOT_TOKEN_VELIA=
# TELEGRAM_WEBHOOK_SECRET_CARIA=
# TELEGRAM_WEBHOOK_SECRET_TEVEN=
# TELEGRAM_WEBHOOK_SECRET_VELIA=
# TELEGRAM_BOT_USERNAME_CARIA=
# TELEGRAM_BOT_USERNAME_TEVEN=
# TELEGRAM_BOT_USERNAME_VELIA=

# Discord
#   https://discord.com/developers/applications → New Application
# DISCORD_APPLICATION_ID=
# DISCORD_PUBLIC_KEY=
# DISCORD_BOT_TOKEN=

# Feishu / Lark
#   https://open.feishu.cn/app → Create app → Credentials & Basic Info
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# WeChat OpenILink
#   Session file path for the OpenILink desktop client bridge (default shown)
# WECHAT_OPENILINK_SESSION_FILE=.openilink-wechat-session.json


# -----------------------------------------------------------------------------
# Internal service secrets  (required if you enable these features)
# Use any long random string: openssl rand -hex 32
# -----------------------------------------------------------------------------

# Follow-up / proactive message cron job
# FOLLOW_UP_CRON_SECRET=
# FOLLOW_UP_DEFAULT_SENDER=stub        # stub | telegram
# FOLLOW_UP_ENABLE_TELEGRAM_SEND=false

# Knowledge base processing worker
# KNOWLEDGE_PROCESSING_SECRET=


# -----------------------------------------------------------------------------
# File storage  (optional — required for character assets and knowledge bases)
#
# Option A: Cloudflare R2 (recommended)
#   https://dash.cloudflare.com → R2 → Create bucket
#
# Option B: S3-compatible
# -----------------------------------------------------------------------------

# Cloudflare R2
# CF_R2_ACCOUNT_ID=
# CF_R2_ACCESS_KEY_ID=
# CF_R2_SECRET_ACCESS_KEY=
# CF_R2_CHARACTER_ASSETS_BUCKET=
# CF_R2_CHARACTER_ASSETS_PUBLIC_BASE_URL=   # public CDN URL for the bucket
# CF_R2_KNOWLEDGE_BUCKET=
# CF_R2_KNOWLEDGE_ACCESS_KEY_ID=
# CF_R2_KNOWLEDGE_SECRET_ACCESS_KEY=

# S3-compatible (alternative to R2)
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=
# S3_BUCKET=
# STORAGE_BUCKET=


# -----------------------------------------------------------------------------
# Billing  (optional — remove or leave blank to disable subscription features)
#   https://creem.io → Dashboard → API keys
#   CREEM_SIMULATE=true keeps billing in test mode (no real charges)
# -----------------------------------------------------------------------------
# CREEM_API_KEY=
# CREEM_WEBHOOK_SECRET=
# CREEM_PRICE_PRO_MONTHLY=
# CREEM_PRICE_PRO_QUARTERLY=
# CREEM_PRICE_PRO_YEARLY=
# CREEM_PRICE_CREDITS_100=
# CREEM_PRICE_CREDITS_250=
# CREEM_PRICE_CREDITS_700=
# CREEM_SIMULATE=true


# -----------------------------------------------------------------------------
# Analytics  (all optional)
# -----------------------------------------------------------------------------

# PostHog — product analytics
#   https://posthog.com → Project Settings → API keys
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Microsoft Clarity — session replay and heatmaps
#   https://clarity.microsoft.com → New project → Setup
# NEXT_PUBLIC_CLARITY_PROJECT_ID=


# -----------------------------------------------------------------------------
# Smoke regression tests  (only needed if running Playwright smoke tests)
#   Create a dedicated test user in your Supabase project.
#   PLAYWRIGHT_SMOKE_SECRET must match the server-side check in /api/test/
# -----------------------------------------------------------------------------
# PLAYWRIGHT_SMOKE_SECRET=
# PLAYWRIGHT_SMOKE_EMAIL=
# PLAYWRIGHT_SMOKE_PASSWORD=
